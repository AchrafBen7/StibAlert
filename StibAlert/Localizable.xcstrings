    "« Pas de pub, pas de tracking. Juste le réseau bruxellois, lisible, pour les gens qui le prennent vraiment. »": {
      "localizations": {
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "«Geen reclame, geen tracking. Gewoon het Brusselse netwerk, leesbaar, voor de mensen die het echt nemen.»"
          }
        }
      }
    },
    "« Toujours bloqué » si le problème dure, « C'est rentré dans l'ordre » s'il est résolu.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "« Still blocked » if the problem persists, « Back to normal » if resolved."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "« Nog steeds geblokkeerd » als het probleem aanhoudt, « Weer in orde » als het is opgelost."
          }
        }
      }
    },
