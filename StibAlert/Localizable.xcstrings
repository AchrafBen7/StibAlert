    "Rouvre la recherche pour changer le trajet." : {
      "comment" : "A hint that appears when a user hovers over the \"Change destination\" button, explaining that it opens the search interface to allow them to change the route.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Heropent de zoekopdracht om de rit te wijzigen."
          }
        }
      }
    },
    "Salut. Je connais l’état du réseau, les alertes officielles, les signalements et ton trajet actif. Pose-moi une question concrète sur tes déplacements." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hi. I know the network status, official alerts, reports and your active trip. Ask me a concrete question about your travels."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hoi. Ik ken de netwerkstatus, officiële meldingen, gebruikersmeldingen en je actieve rit. Stel me een concrete vraag over je verplaatsingen."
          }
        }
      }
    },
    "Sans position, on ne peut pas proposer des arrêts réellement à proximité." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Without location, we can't suggest truly nearby stops."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zonder locatie kunnen we geen echt nabije haltes voorstellen."
          }
        }
      }
    },
    "Sauvegarde tes lignes et arrêts" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Save your lines and stops"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bewaar je lijnen en haltes"
          }
        }
      }
    },
    "Scanne ta MoBIB en NFC ou complète\nmanuellement les champs ci-dessous." : {
      "extractionState" : "stale",
      "localizations" : {
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Scan je MoBIB via NFC of vul\nde velden hieronder handmatig in."
          }
        }
      }
    },
