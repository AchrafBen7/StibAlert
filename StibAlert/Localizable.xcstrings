    "Rouvre la recherche pour changer le trajet.": {
      "comment": "A hint that appears when a user hovers over the \"Change destination\" button, explaining that it opens the search interface to allow them to change the route.",
      "isCommentAutoGenerated": true,
      "localizations": {
