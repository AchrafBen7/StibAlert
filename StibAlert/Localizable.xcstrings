    "%@ – %lld signalements" : {
      "comment" : "A text that shows the current status of a public transport line, followed by the number of signalements associated with it. The first argument is the localized string representing the status of the line. The second argument is the count of signalements for that line.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ – %2$lld signalements"
          }
        }
      }
    },
    "%@ • %@" : {
      "comment" : "A text label displaying the route code and a human-readable description of a STIB vehicle. The first argument is the route code of the vehicle. The second argument is a human-readable description of the vehicle.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ • %2$@"
          }
        }
      }
    },
    "%@ → %@" : {
      "comment" : "The main content of the view, including the origin and destination locations, estimated travel time, and public transport details.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ → %2$@"
          }
        }
      }
    },
    "%@: " : {
      "comment" : "A row in the report confirmation view, displaying a title and its corresponding content. The first argument is the title of the row. The second argument is the content of the row.",
      "isCommentAutoGenerated" : true
    },
